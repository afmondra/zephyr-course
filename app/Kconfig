mainmenu "Blinky Heartbeat Configuration"

config APP_HEARTBEAT_PERIOD_MS
    int "Heartbeat LED period (ms)"
    default 500
    range 100 2000
    help
      Blink half-period in milliseconds — the LED stays on for this
      duration, then off for the same duration.
      Range: 100 ms (fast) to 2000 ms (slow).


# ============================================================
# LED Subsystem
# ============================================================
menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y
    help
      Enable the LED subsystem. When disabled, all LED-related
      symbols are hidden and excluded from the build.

if LED_SUBSYSTEM

# ------------------------------------------------------------
# Blink sleep time
# ------------------------------------------------------------
choice LED_BLINK_SLEEP
    prompt "LED blink sleep time"
    default LED_BLINK_SLEEP_1000

config LED_BLINK_SLEEP_250
    bool "250ms (fast)"

config LED_BLINK_SLEEP_500
    bool "500ms (medium-fast)"

config LED_BLINK_SLEEP_1000
    bool "1s (medium)"

config LED_BLINK_SLEEP_2000
    bool "2s (slow)"

endchoice

# Hidden int — resolved at build time from the choice selection.
# Use CONFIG_LED_BLINK_SLEEP_MS directly in C / DTS overlays.
config LED_BLINK_SLEEP_MS
    int
    default 250  if LED_BLINK_SLEEP_250
    default 500  if LED_BLINK_SLEEP_500
    default 1000 if LED_BLINK_SLEEP_1000
    default 2000 if LED_BLINK_SLEEP_2000

# ------------------------------------------------------------
# Advanced LED settings
# ------------------------------------------------------------
menuconfig LED_ADVANCED
    bool "Advanced LED settings"
    default n
    help
      Expose advanced LED tuning parameters.
      Disable to keep the build configuration minimal.

if LED_ADVANCED

config LED_BRIGHTNESS
    int "LED brightness (0-100)"
    default 100
    range 0 100
    help
      Static brightness level applied to all LEDs.
      0 = off, 100 = full brightness.

config LED_FADE_DURATION
    int "LED fade duration (ms)"
    default 500
    range 0 5000
    help
      Duration of the fade-in / fade-out transition.
      Set to 0 to disable fading entirely.

# ------------------------------------------------------------
# Expert settings  (visible only when Advanced is enabled —
# uses 'visible if' so symbols still exist but the submenu
# is hidden when the condition is false)
# ------------------------------------------------------------
menu "Expert settings"
    visible if LED_ADVANCED

config LED_DEBUG
    bool "Enable LED debugging"
    default n
    depends on LED_ADVANCED
    help
      Emit debug-level log messages from the LED driver.
      Requires CONFIG_LOG=y to have any effect.

config LED_CUSTOM_BLINK_PATTERN
    bool "Custom blink pattern"
    default n
    depends on LED_ADVANCED
    help
      Replace the built-in blink pattern with a user-defined
      sequence configured at runtime.

endmenu  # Expert settings

endif  # LED_ADVANCED

endif  # LED_SUBSYSTEM

config BOARD_OUR_BOARD
select BOARD_NRF5340DK_NRF5340_CPUAPP if BOARD_OUR_BOARD
    bool "Our custom board"
    help
      Enable support for our custom board. This will pull in the
      necessary drivers and configurations to run Zephyr on it.

#rsource "drivers/Kconfig"

source "Kconfig.zephyr"
rsource "drivers/our_driver/Kconfig"
