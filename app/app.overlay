/ {

    aliases {
        app-led = &led0;
    };
        our_driver0: our_driver {
        compatible = "our,driver";
        gpios = <&gpio0 28 GPIO_ACTIVE_LOW>;
        status = "okay";
    };
        our_driver1: our_driver1 {
        compatible = "our,driver";
        gpios = <&gpio0 29 GPIO_ACTIVE_LOW>;
        status = "okay";
    };

};

