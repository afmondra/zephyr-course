# LED Subsystem top-level menu (the [*] means bool, default y)
config LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM

# Blink sleep time — choice menu (the "--->" indicates a choice block)
choice LED_BLINK_SLEEP
    prompt "LED blink sleep time"
    default LED_BLINK_SLEEP_MEDIUM

config LED_BLINK_SLEEP_SLOW
    bool "2s (slow)"

config LED_BLINK_SLEEP_MEDIUM
    bool "1s (medium)"

config LED_BLINK_SLEEP_FAST
    bool "500ms (fast)"

endchoice

# Advanced LED settings submenu
menuconfig LED_ADVANCED
    bool "Advanced LED settings"
    default n

if LED_ADVANCED

config LED_BRIGHTNESS
    int "LED brightness (0-100)"
    default 100
    range 0 100

config LED_FADE_DURATION
    int "LED fade duration (ms)"
    default 500
    range 0 10000

# Expert settings submenu (nested inside Advanced)
menu "Expert settings"

config LED_DEBUG
    bool "Enable LED debugging"
    default n

config LED_CUSTOM_BLINK_PATTERN
    bool "Custom blink pattern"
    default n

endmenu  # Expert settings

endif  # LED_ADVANCED

endif  # LED_SUBSYSTEM